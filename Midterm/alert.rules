groups:
  - name: alerts
    rules:
      - alert: HighErrorRate
        expr: rate(http_requests_total{status=~"5.."}[1m]) > 0.05
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "high error rate detected"

      - alert: ServerDown
        expr: up{instance="server:4000", job="server"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "server is down"